# Criar/atualizar .gitignore
cat > .gitignore << 'EOF'
# Configurações sensíveis
config.json
*.env
.env

# Dados do bot
data/
*.db
*.sqlite

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Testes
.pytest_cache/
.coverage
htmlcov/
EOF